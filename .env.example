# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Better Auth
# ─────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# (Optional) Comma-separated list of additional trusted origins for Better Auth.
# Required when testing from other devices on your local network (e.g. iPhone/Android).
# Set this to your Mac's LAN IP: http://192.168.x.x:3000
# Find your LAN IP with: ipconfig getifaddr en0
BETTER_AUTH_TRUSTED_ORIGINS=

# ─────────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full
DATABASE_URL=

# ─────────────────────────────────────────────
# Email (SMTP / Nodemailer)
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
# Set to "true" only for port 465 (SMTPS); use "false" for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Display name and address shown in the "From" field
SMTP_FROM="Mi App <noreply@example.com>"
